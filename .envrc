export UV_DEFAULT_INDEX=https://pypi.org/simple

# cl9 shell completion — write to FPATH so zsh picks it up
_cl9_comp_dir="${XDG_CACHE_HOME:-$HOME/.cache}/cl9/completions"
mkdir -p "$_cl9_comp_dir"
_CL9_COMPLETE=zsh_source cl9 > "$_cl9_comp_dir/_cl9" 2>/dev/null || true
path_add FPATH "$_cl9_comp_dir"
